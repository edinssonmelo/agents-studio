# Copy to .env — never commit .env

# Public hostname users type in the browser (used for Traefik Host rule)
DOMAIN=studio.example.com

# Browser origin for CORS (default: https://$DOMAIN). For local HTTP use: http://localhost:3000
# FRONTEND_ORIGIN=http://localhost:3000

# JWT signing secret (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Studio login accounts (logical operators; rename in code if you need more)
USER_ME_PASSWORD=change-me
USER_WIFE_PASSWORD=change-me

# agent_core — internal URL on the Docker network
AGENT_CORE_URL=http://agent_core:8766
AGENT_CORE_TOKEN=match-the-token-configured-on-agent-core
AGENT_CORE_TIMEOUT=90000

# Host paths mounted into the API container (must match where agent_core reads/writes)
AGENT_CORE_CONFIG_PATH=/path/to/agent-core
AGENT_CORE_DATA_PATH=/path/to/agent-core-data

# Paths inside the API container (defaults are fine unless you change Dockerfile)
AGENT_CORE_CONFIG_ROOT=/data/agent-core
AGENT_CORE_DATA_ROOT=/data/agent-core-data
