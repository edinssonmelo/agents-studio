# .env.example
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Domain ────────────────────────────────────────────────────────────────
DOMAIN=agents.edinssonmelo.com

# ── JWT Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-very-long-random-string
JWT_EXPIRES_IN=8h

# Passwords for studio users (me / wife).
# For bcrypt hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpw', bcrypt.gensalt()).decode())"
# Plain text works in dev; use bcrypt in production.
USER_ME_PASSWORD=change-me-secure-password
USER_WIFE_PASSWORD=change-me-secure-password

# ── agent_core connection ─────────────────────────────────────────────────
# Internal hostname — never reaches the public internet
AGENT_CORE_URL=http://agent_core:8766
# Same token as in your infra .env (AGENT_CORE_TOKEN)
AGENT_CORE_TOKEN=your-agent-core-token-from-infra-env
AGENT_CORE_TIMEOUT=90000

# ── Volume paths (host → container) ──────────────────────────────────────
# Path to agent-core CODE directory (contains assistants.yaml + prompts/)
# This is the same path used by the running agent_core container.
AGENT_CORE_CONFIG_PATH=/srv/apps/infra/agent-core

# Path to agent-core DATA directory (contains users/{me,wife}/agents/*/memory.md)
AGENT_CORE_DATA_PATH=/srv/data/agent-core

# ── Internal container env (usually no need to change) ───────────────────
AGENT_CORE_CONFIG_ROOT=/data/agent-core
AGENT_CORE_DATA_ROOT=/data/agent-core-data
