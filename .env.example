# Copy to .env — never commit .env

# Public hostname (Traefik Host rule + CORS default). For local dev with published port: localhost
DOMAIN=studio.example.com

# Browser origin for CORS (default: https://$DOMAIN). Local HTTP example:
# FRONTEND_ORIGIN=http://localhost:3000

# JWT signing secret (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Studio login accounts (logical operators me / wife)
USER_ME_PASSWORD=change-me
USER_WIFE_PASSWORD=change-me

# agent_core — same Docker network as api (service name agent_core)
AGENT_CORE_URL=http://agent_core:8766
AGENT_CORE_TOKEN=match-the-token-configured-on-agent-core
AGENT_CORE_TIMEOUT=90000

# LLM key for agent_core (DeepSeek API). Required for real /run responses.
DEEPSEEK_API_KEY=

# Host paths mounted into api + agent_core (defaults in docker-compose: repo config + ./data)
AGENT_CORE_CONFIG_PATH=./apps/agent-core
AGENT_CORE_DATA_PATH=./data/agent-core-data

# Paths inside containers (defaults match Dockerfile / compose — change only if you customize mounts)
AGENT_CORE_CONFIG_ROOT=/data/agent-core
AGENT_CORE_DATA_ROOT=/data/agent-core-data

LOG_LEVEL=INFO
