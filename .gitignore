# .gitignore

# Environment — never commit real secrets
.env
.env.local
.env.*.local

# Node
node_modules/
apps/*/node_modules/

# Next.js
apps/web/.next/
apps/web/out/

# NestJS
apps/api/dist/

# SQLite
*.db
*.db-journal
*.db-wal

# Build artifacts
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Coverage
coverage/
